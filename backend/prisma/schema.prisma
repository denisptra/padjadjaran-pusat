generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String               @id @default(uuid())
  email            String               @unique
  passwordHash     String
  role             Role                 @default(member)
  refreshTokenHash String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  status           UserStatus           @default(PENDING)
  emailVerifiedAt  DateTime?
  announcements    Announcement[]
  readAnnounces    AnnouncementRead[]
  approvals        Approval[]           @relation("CreatedApprovals")
  processedApprovs Approval[]           @relation("ProcessedApprovals")
  auditLogs        AuditLog[]
  profile          MemberProfile?
  otpTokens        OtpToken[]
  resetTokens      PasswordResetToken[]
  payments         Payment[]
  refreshTokens    RefreshToken[]
  managedRegion    Region?              @relation("RegionAdmin")
  notifications    Notification[]

  @@index([email])
}

model MemberProfile {
  id               String     @id @default(uuid())
  userId           String     @unique
  fullName         String?
  nik              String?    @unique
  phone            String?    @unique
  gender           String?
  birthPlace       String?
  birthDate        DateTime?
  address          String?
  memberType       MemberType @default(umum)
  registrationStep Int        @default(0)
  photoUrl         String?
  documentUrl      String?
  ktaNumber        String?
  regionId         String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  nationality      String?    @default("WNI")
  region           Region?    @relation(fields: [regionId], references: [id])
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Province {
  id         String   @id @default(uuid())
  name       String   @unique
  isOverseas Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  regions    Region[]
}

model Region {
  id          String          @id @default(uuid())
  name        String          @unique
  provinceId  String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  adminId     String?         @unique
  address     String?
  description String?
  leaderName  String?
  phone       String?
  members     MemberProfile[]
  admin       User?           @relation("RegionAdmin", fields: [adminId], references: [id])
  province    Province?       @relation(fields: [provinceId], references: [id])
}

model OtpToken {
  id           String    @id @default(uuid())
  userId       String
  otpHash      String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())
  attemptCount Int       @default(0)
  email        String
  purpose      String    @default("email_verify")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Approval {
  id          String   @id @default(uuid())
  creatorId   String
  type        String   @default("registration")
  status      String   @default("pending")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  processorId String?
  creator     User     @relation("CreatedApprovals", fields: [creatorId], references: [id])
  processor   User?    @relation("ProcessedApprovals", fields: [processorId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model PaymentSetting {
  id            String   @id @default(uuid())
  type          String   @unique
  amount        Float
  bankName      String?
  accountNumber String?
  accountOwner  String?
  instruction   String?
  whatsapp      String?
  messageFormat String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  type      String   @default("REGISTRATION")
  status    String   @default("pending")
  proofUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Announcement {
  id              String             @id @default(uuid())
  title           String
  content         String
  authorId        String
  isPublished     Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  showModal       Boolean            @default(false)
  scope           AnnouncementScope  @default(national)
  targetProvinces String[]
  targetRegions   String[]
  author          User               @relation(fields: [authorId], references: [id])
  readBy          AnnouncementRead[]
}

model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model ActionMatrix {
  id        String   @id @default(uuid())
  role      Role
  action    String
  isAllowed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, action])
}

model FeatureControl {
  id          String   @id @default(uuid())
  key         String   @unique
  isEnabled   Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CmsGallery {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  description String?
  category    String   @default("umum")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CmsGuruBesar {
  id          String   @id @default(uuid())
  name        String
  title       String?
  description String?
  imageUrl    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CmsHeroSlider {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CmsPublication {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  content     String
  type        PublicationType @default(BERITA)
  category    String          @default("umum")
  imageUrl    String?
  isPublished Boolean         @default(false)
  publishedAt DateTime?
  viewCount   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageView {
  id         String   @id @default(uuid())
  path       String
  sessionId  String
  source     String?
  deviceType String?
  visitedAt  DateTime @default(now())
}

model ContentView {
  id          String   @id @default(uuid())
  contentId   String
  contentType String
  sessionId   String
  visitedAt   DateTime @default(now())
}

enum Role {
  member
  admin_wilayah
  admin_pusat
  super_admin
}

enum MemberType {
  pencak_silat
  umum
  khusus
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum AnnouncementScope {
  national
  province
  region
}

enum PublicationType {
  BERITA
  ARTIKEL
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  content     String
  type        String   // e.g. "ANNOUNCEMENT", "PAYMENT", "APPROVAL", "SYSTEM"
  referenceId String?  // ID from paymentId, approvalId, etc.
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

