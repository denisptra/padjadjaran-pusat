# Application
APP_PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/padjajaran?schema=public"

# Security
JWT_ACCESS_SECRET=your_access_secret_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7
ENCRYPTION_KEY=32_character_string_for_aes_here

# Email Provider (brevo, resend, smtp, ethereal)
MAIL_PROVIDER=ethereal
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_brevo_user
SMTP_PASS=your_brevo_password
SMTP_FROM="PPS Padjadjaran <noreply@domain.com>"

RESEND_API_KEY=your_resend_api_key_here

# Throttler
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
